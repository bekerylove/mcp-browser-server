{
  "name": "mcp-browser-server",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server for browser automation using Playwright",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "install-browsers": "playwright install chromium",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["mcp", "browser", "automation", "playwright", "model-context-protocol"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "playwright": "^1.48.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
